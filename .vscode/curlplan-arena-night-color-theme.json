    "peekViewEditor.matchHighlightBackground": "#004990AA",
    "peekViewResult.background": "#0F1728",
    "peekViewResult.matchHighlightBackground": "#004990AA",
    "peekViewResult.selectionBackground": "#004990",
    "peekViewTitle.background": "#0B1020",
