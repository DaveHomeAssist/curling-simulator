  "tokenColors": [
    {
      "name": "Reset / base text",
      "scope": ["source", "text"],
      "settings": { "foreground": "#C8D8E8" }
    },
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#2F4F6A", "fontStyle": "italic" }
    },
    {
      "name": "Doc comments",
      "scope": ["comment.block.documentation"],
      "settings": { "foreground": "#3A6A8A", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.other.important"
      ],
      "settings": { "foreground": "#00E7FF", "fontStyle": "" }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.if",
        "keyword.control.else",
        "keyword.control.for",
        "keyword.control.while"
      ],
      "settings": { "foreground": "#6BCFFF", "fontStyle": "italic" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#5A8AAA" }
    },
    {
      "name": "Spread / rest",
      "scope": ["keyword.operator.spread", "keyword.operator.rest"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "Storage modifiers (const/let/var/async)",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#00E7FF" }
    },
    {
      "name": "Primitive types",
      "scope": ["support.type.primitive", "keyword.type"],
      "settings": { "foreground": "#6BCFFF" }
    },
    {
      "name": "Function names — declaration",
      "scope": ["entity.name.function", "meta.definition.method entity.name.function"],
      "settings": { "foreground": "#ABFF9A", "fontStyle": "" }
    },
    {
      "name": "Class names",
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": { "foreground": "#FF9600", "fontStyle": "" }
    },
    {
      "name": "Constructor",
      "scope": ["entity.name.function.constructor"],
      "settings": { "foreground": "#FFB733" }
    },
    {
      "name": "Interface / type alias",
      "scope": ["entity.name.type.interface", "entity.name.type.alias"],
      "settings": { "foreground": "#C6B26A" }
    },
    {
      "name": "Enum names",
      "scope": ["entity.name.type.enum"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "Variable declarations",
      "scope": ["variable.other.readwrite", "variable.other.assignment"],
      "settings": { "foreground": "#C8D8E8" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#B7C5D6", "fontStyle": "italic" }
    },
    {
      "name": "This / self",
      "scope": ["variable.language.this", "variable.language.self"],
      "settings": { "foreground": "#00E7FF", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#C6B26A" }
    },
    {
      "name": "Template literals",
      "scope": ["string.template"],
      "settings": { "foreground": "#DFC880" }
    },
    {
      "name": "Template expression inside ${}",
      "scope": ["meta.template.expression"],
      "settings": { "foreground": "#C8D8E8" }
    },
    {
      "name": "String escape sequences",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "Boolean / null / undefined",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": { "foreground": "#E42734" }
    },
    {
      "name": "Other language constants",
      "scope": ["constant.language"],
      "settings": { "foreground": "#6BCFFF" }
    },
    {
      "name": "Constant names (ALL_CAPS)",
      "scope": ["variable.other.constant"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "Object / member properties",
      "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"],
      "settings": { "foreground": "#6BCFFF" }
    },
    {
      "name": "Function calls",
      "scope": ["meta.function-call entity.name.function", "variable.function"],
      "settings": { "foreground": "#ABFF9A" }
    },
    {
      "name": "Built-in support functions",
      "scope": ["support.function"],
      "settings": { "foreground": "#ABFF9A", "fontStyle": "" }
    },
    {
      "name": "Built-in constants",
      "scope": ["support.constant"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "Import path string",
      "scope": ["meta.import string"],
      "settings": { "foreground": "#C6B26A" }
    },
    {
      "name": "Import keyword",
      "scope": ["keyword.control.import", "keyword.control.export"],
      "settings": { "foreground": "#00E7FF" }
    },
    {
      "name": "Module name / namespace",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "storage.type.annotation",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#CC7800", "fontStyle": "italic" }
    },
    {
      "name": "Brackets / parens / braces",
      "scope": ["punctuation.definition", "meta.brace", "punctuation.bracket"],
      "settings": { "foreground": "#4A6A8A" }
    },
    {
      "name": "Semicolons / commas",
      "scope": ["punctuation.terminator", "punctuation.separator"],
      "settings": { "foreground": "#2A3F5F" }
    },
    {
      "name": "JSX tag names",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#00E7FF" }
    },
    {
      "name": "JSX component names (PascalCase)",
      "scope": ["support.class.component"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "HTML/JSX attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#6BCFFF" }
    },
    {
      "name": "JSX expression braces",
      "scope": ["punctuation.section.embedded"],
      "settings": { "foreground": "#CC7800" }
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class"],
      "settings": { "foreground": "#00E7FF" }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#6BCFFF" }
    },
    {
      "name": "CSS property values",
      "scope": ["support.constant.property-value.css", "meta.property-value"],
      "settings": { "foreground": "#C6B26A" }
    },
    {
      "name": "CSS variables (--custom-props)",
      "scope": ["variable.css", "variable.other.custom-property.name.css"],
      "settings": { "foreground": "#ABFF9A" }
    },
    {
      "name": "CSS units",
      "scope": ["keyword.other.unit.css"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "CSS at-rules",
      "scope": ["keyword.control.at-rule", "punctuation.definition.keyword.css"],
      "settings": { "foreground": "#00E7FF", "fontStyle": "italic" }
    },
    {
      "name": "CSS hex colors",
      "scope": ["constant.other.color.rgb-value.hex.css"],
      "settings": { "foreground": "#FF9600" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#00E7FF", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#F8FAFC", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#B7C5D6", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw"],
      "settings": { "foreground": "#ABFF9A" }
    },
    {
      "name": "Markdown code block",
      "scope": ["markup.fenced_code"],
      "settings": { "foreground": "#C8D8E8" }
    },
    {
      "name": "Markdown link text",
      "scope": ["string.other.link.title.markdown"],
      "settings": { "foreground": "#6BCFFF" }
    },
    {
      "name": "Markdown link URL",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#CC7800" }
    },
    {
      "name": "Markdown list bullet",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#004990" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#3A6A8A", "fontStyle": "italic" }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#6BCFFF" }
    },
    {
      "name": "JSON string values",
      "scope": ["string.quoted.double.json"],
      "settings": { "foreground": "#C6B26A" }
    },
    {
      "name": "Python decorators",
      "scope": ["meta.function.decorator.python"],
      "settings": { "foreground": "#CC7800", "fontStyle": "italic" }
    },
    {
      "name": "Python self",
      "scope": ["variable.parameter.function.language.special.self.python"],
      "settings": { "foreground": "#00E7FF", "fontStyle": "italic" }
    },
    {
      "name": "Python magic methods",
      "scope": ["support.function.magic.python"],
      "settings": { "foreground": "#ABFF9A", "fontStyle": "italic" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#FF4D57", "fontStyle": "underline" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#B8860B", "fontStyle": "strikethrough" }
    }
  ],
  "semanticTokenColors": {
    "variable": "#C8D8E8",
    "variable.defaultLibrary": "#6BCFFF",
    "parameter": { "foreground": "#B7C5D6", "italic": true },
    "function": "#ABFF9A",
    "function.defaultLibrary": "#ABFF9A",
    "method": "#ABFF9A",
    "property": "#6BCFFF",
    "property.readonly": { "foreground": "#6BCFFF", "italic": true },
    "class": "#FF9600",
    "interface": "#C6B26A",
    "enum": "#FF9600",
    "enumMember": "#FF9600",
    "type": "#C6B26A",
    "typeParameter": "#C6B26A",
    "namespace": "#FF9600",
    "decorator": { "foreground": "#CC7800", "italic": true },
    "keyword": "#00E7FF",
    "string": "#C6B26A",
    "number": "#FF9600",
    "regexp": "#FF9600",
    "operator": "#5A8AAA",
    "comment": { "foreground": "#2F4F6A", "italic": true },
    "macro": "#FF9600",
    "label": "#6BCFFF",
    "selfKeyword": { "foreground": "#00E7FF", "italic": true },
    "superKeyword": { "foreground": "#00E7FF", "italic": true }
  }
}
