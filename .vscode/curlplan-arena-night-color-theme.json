    "breadcrumbPicker.background": "#0F1728",
    "minimap.background": "#080D18",
    "minimap.selectionHighlight": "#004990AA",
    "minimap.findMatchHighlight": "#CC7800",
    "minimap.errorHighlight": "#E42734",
    "minimap.warningHighlight": "#FF9600",
    "minimapSlider.background": "#1E2A4466",
    "minimapSlider.hoverBackground": "#1E2A44AA",
    "minimapSlider.activeBackground": "#004990AA",
    "focusBorder": "#00E7FF",
    "contrastBorder": "#00000000",
    "widget.shadow": "#00000088",
    "selection.background": "#004990AA",
    "icon.foreground": "#5A7A9A"
