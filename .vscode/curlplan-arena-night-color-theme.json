    "inputValidation.warningBackground": "#CC780022",
    "inputValidation.warningBorder": "#CC7800",
    "inputValidation.errorBackground": "#E4273422",
    "inputValidation.errorBorder": "#E42734",
    "dropdown.background": "#121A2B",
    "dropdown.listBackground": "#0F1728",
    "dropdown.foreground": "#C8D8E8",
    "dropdown.border": "#1E2A44",
    "scrollbar.shadow": "#00000055",
    "scrollbarSlider.background": "#1E2A4488",
    "scrollbarSlider.hoverBackground": "#1E2A44CC",
    "scrollbarSlider.activeBackground": "#004990",
    "badge.background": "#004990",
    "badge.foreground": "#FFFFFF",
    "notificationCenterHeader.background": "#080D18",
    "notificationCenterHeader.foreground": "#5A7A9A",
    "notifications.background": "#121A2B",
    "notifications.foreground": "#C8D8E8",
    "notifications.border": "#1E2A44",
    "notificationLink.foreground": "#00E7FF",
    "button.background": "#004990",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#003670",
    "button.secondaryBackground": "#1A2A40",
    "button.secondaryForeground": "#C8D8E8",
    "button.secondaryHoverBackground": "#1E3050",
    "textLink.foreground": "#00E7FF",
