    "terminal.ansiWhite": "#C8D8E8",
    "terminal.ansiBrightBlack": "#2A3F5F",
    "terminal.ansiBrightRed": "#FF4D57",
    "terminal.ansiBrightGreen": "#ABFF9A",
    "terminal.ansiBrightYellow": "#FFB733",
    "terminal.ansiBrightBlue": "#6BCFFF",
    "terminal.ansiBrightMagenta": "#C6B26A",
    "terminal.ansiBrightCyan": "#00E7FF",
    "terminal.ansiBrightWhite": "#F8FAFC",
    "input.background": "#121A2B",
    "input.foreground": "#C8D8E8",
    "input.border": "#1E2A44",
    "input.placeholderForeground": "#3A5A7A",
    "inputOption.activeBackground": "#004990",
    "inputOption.activeForeground": "#FFFFFF",
    "inputOption.activeBorder": "#00E7FF",
    "inputValidation.infoBackground": "#00E7FF22",
